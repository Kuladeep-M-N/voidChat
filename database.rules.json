{
  "rules": {
    "presence": {
      ".read": "auth != null",
      "$roomId": {
        "$uid": {
          ".write": "auth != null && $uid === auth.uid",
          "username": { ".validate": "newData.isString()" },
          "speaking": { ".validate": "newData.isBoolean()" },
          "muted": { ".validate": "newData.isBoolean()" },
          "role": { ".validate": "newData.val() === 'speaker' || newData.val() === 'audience'" },
          "handRaised": { ".validate": "newData.isBoolean()" }
        }
      }
    },
    "signaling": {
      "$roomId": {
        "$uid": {
          ".read": "auth != null && $uid === auth.uid",
          ".write": "auth != null",
          "$signalId": {
            ".validate": "newData.hasChildren(['from', 'type', 'data'])"
          }
        }
      }
    },
    "chat": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$messageId": {
          ".validate": "newData.hasChildren(['userId', 'username', 'text'])"
        }
      }
    },
    "reactions": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$reactionId": {
          ".validate": "newData.hasChildren(['emoji', 'userId', 'timestamp'])"
        }
      }
    },
    ".read": false,
    ".write": false
  }
}