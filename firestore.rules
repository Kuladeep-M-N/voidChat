rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_admin == true;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isSafeModeActive() {
      return get(/databases/$(database)/documents/system_config/global).data.safeMode == true;
    }
    
    function canCreateContent() {
      return isAuthenticated() && (!isSafeModeActive() || isAdmin());
    }

    // Users collection
    match /users/{userId} {
      allow read: if true; 
      allow write: if isOwner(userId) || isAdmin();
    }

    // Chat Rooms
    match /chat_rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if canCreateContent();
      allow update: if canCreateContent();
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.created_by == request.auth.uid);
    }

    // Room Members
    match /room_members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if canCreateContent();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }

    // Messages
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if canCreateContent();
      allow delete: if isAdmin();
    }

    // Confessions
    match /confessions/{confessionId} {
      allow read: if isAuthenticated();
      allow create: if canCreateContent();
      allow update: if isAuthenticated(); // For likes
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }

    // Confession Comments
    match /confession_comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if canCreateContent();
      allow delete: if isAdmin();
    }

    // Shoutouts
    match /shoutouts/{shoutoutId} {
      allow read: if isAuthenticated();
      allow create: if canCreateContent();
      allow update: if canCreateContent();
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }

    // Debates
    match /debates/{debateId} {
      allow read: if isAuthenticated();
      allow create: if canCreateContent();
      allow update: if canCreateContent();
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }

    // Debate Arguments
    match /debate_arguments/{argId} {
      allow read: if isAuthenticated();
      allow create: if canCreateContent();
      allow update: if canCreateContent();
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }

    // Polls
    match /polls/{pollId} {
      allow read: if isAuthenticated();
      allow create: if canCreateContent();
      allow update: if canCreateContent() && (isAdmin() || resource.data.created_by == request.auth.uid);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.created_by == request.auth.uid);
    }

    // Poll Votes
    match /poll_votes/{voteId} {
      allow read: if isAuthenticated();
      // Users can only write their own vote using a composite ID {pollId}_{userId}
      allow create, update: if canCreateContent() && request.auth.uid == request.resource.data.user_id;
      allow delete: if isAdmin();
    }
    
    // Reports
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // Always allow reporting
      allow update, delete: if isAdmin();
    }
    
    // System Config
    match /system_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Default catch-all
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin(); 
    }
  }
}
