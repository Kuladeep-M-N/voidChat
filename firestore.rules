rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isModerator() {
      return isAuthenticated() && (getUserRole() == 'moderator' || getUserRole() == 'admin');
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isNotExpired() {
      return !('expires_at' in resource.data) || resource.data.expires_at > request.time;
    }

    function isSafeModeActive() {
      return get(/databases/$(database)/documents/system_config/global).data.safeMode == true;
    }
    
    function canCreateContent() {
      return isAuthenticated() && (!isSafeModeActive() || isModerator());
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated(); 
      allow write: if isOwner(userId) || isAdmin();
    }

    // Chat Rooms
    match /chat_rooms/{roomId} {
      allow read: if isAuthenticated() && isNotExpired();
      allow create: if canCreateContent();
      allow update: if canCreateContent() && (isOwner(resource.data.created_by) || isModerator());
      allow delete: if isModerator() || (isAuthenticated() && resource.data.created_by == request.auth.uid);
    }

    // Room Members
    match /room_members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if canCreateContent();
      allow update, delete: if isModerator() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }

    // Messages
    match /messages/{messageId} {
      allow read: if isAuthenticated() && isNotExpired();
      allow create: if canCreateContent();
      allow delete: if isModerator();
    }

    // Confessions
    match /confessions/{confessionId} {
      allow read: if isAuthenticated() && isNotExpired();
      allow create: if canCreateContent();
      allow update: if isAuthenticated(); // For likes
      allow delete: if isModerator() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }

    // Shoutouts
    match /shoutouts/{shoutoutId} {
      allow read: if isAuthenticated() && isNotExpired();
      allow create: if canCreateContent();
      allow delete: if isModerator() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }

    // Reports
    match /reports/{reportId} {
      allow read: if isModerator();
      allow create: if isAuthenticated();
      allow update, delete: if isModerator();
    }
    
    // System Config
    match /system_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Default catch-all - Deny by default, only allow explicit rules above
    match /{document=**} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAdmin(); 
    }
  }
}
